# Langfuse credentials. Copy to .env and fill in your project keys.
# Get these from your Langfuse project settings (Setup -> API Keys).
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Region host: https://cloud.langfuse.com (EU) or https://us.cloud.langfuse.com (US),
# or your self-hosted URL.
LANGFUSE_BASE_URL=https://cloud.langfuse.com
